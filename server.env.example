# Server bot environment variables
# Copy this file to /etc/bots/server.env on your server and fill in your values.
# Never commit the real server.env file to git.

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=your-telegram-bot-token-here

# Telegram chat ID to send messages to (your personal chat or a group)
TELEGRAM_CHAT_ID=your-chat-id-here

# Space-separated list of domains to monitor for SSL expiry and /api/health checks
MONITORED_DOMAINS="example.com another.com"

# Space-separated list of systemd services to monitor in /status and daily reports
MONITORED_SERVICES="nginx postgresql fail2ban"

# Alert thresholds — proactive alerts fire when these are exceeded
DISK_WARN_PCT=80        # alert when disk usage hits this percentage
CERT_WARN_DAYS=14       # warn when SSL cert expires within this many days

# How often the bot checks services and disk in the background (minutes)
ALERT_INTERVAL_MINUTES=5
